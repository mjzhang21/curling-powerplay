% ====================
% Definitions (Minimal Tweaks)
% ====================

\definecolor{lightgray}{RGB}{250, 250, 252}   % slightly softer than white
\definecolor{blue}{RGB}{0, 14, 47}        % unchanged, main accent
\definecolor{darkblue}{RGB}{0, 14, 47}     % unchanged, strong accent
\definecolor{lightblue}{RGB}{210, 230, 255}  % slightly darker for alert blocks

% ====================
% Theme (Minimal Tweaks)
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=darkblue}

% Headline
\setbeamercolor{headline}{fg=white,bg=blue}      % changed fg to white for better contrast
\setbeamercolor{headline rule}{bg=darkblue}

% Block
\setbeamercolor{block title}{fg=darkblue,bg=white}       % slightly darker title for hierarchy
\setbeamercolor{block separator}{bg=black}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block title alerted}{fg=blue,bg=lightblue}  % slightly darker background
\setbeamercolor{block separator alerted}{bg=black}
\setbeamercolor{block body alerted}{fg=black,bg=lightblue}

% Example Block
\setbeamercolor{block title example}{fg=blue,bg=lightgray}  % subtle soft background
\setbeamercolor{block separator example}{bg=black}
\setbeamercolor{block body example}{fg=black,bg=lightgray}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=darkblue}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}